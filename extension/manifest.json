{
  "manifest_version": 3,
  "name": "SignalFlow – Save LinkedIn Leads",
  "version": "1.1.0",
  "description": "Capture LinkedIn profiles as leads and send them to your SignalFlow dashboard with one click.",
  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.replit.app/*",
    "https://*.replit.dev/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
